{
  "version": "0.1.0",
  "last_reviewed": "2026-06-10",
  "risk_markers": [
    {
      "id": "R1",
      "label": "Policy ambiguity",
      "description": "Eligibility, unit cost, budget mapping, or authority is unclear enough to create downstream discretion."
    },
    {
      "id": "R2",
      "label": "Release or float mismatch",
      "description": "Allocation, release, SNA/TSA/CNA, state IFMS, and expenditure records do not reconcile."
    },
    {
      "id": "R3",
      "label": "Beneficiary-list gatekeeping",
      "description": "Local verification, list changes, duplicate records, or exclusion patterns require review."
    },
    {
      "id": "R4",
      "label": "Works or procurement leakage",
      "description": "Tender, vendor, measurement, invoice, delivery, or quality records do not reconcile."
    },
    {
      "id": "R5",
      "label": "Payment or identity failure",
      "description": "PFMS/APB/bank/payment records show failed, returned, delayed, duplicate, or mismatched credit."
    },
    {
      "id": "R6",
      "label": "Oversight non-response",
      "description": "Audit, RTI, grievance, social-audit, vigilance, or court-linked issue lacks timely closure."
    },
    {
      "id": "R7",
      "label": "Data integrity gap",
      "description": "Identifiers, dates, locations, amounts, or update windows do not map safely across systems."
    }
  ],
